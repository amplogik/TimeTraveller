#!/usr/bin/env python3
"""Entry shim that runs without installation.

Adds the repo root to sys.path so `from timetraveller import ...` works when
you're running directly out of a checkout (no pip install needed).
"""
import os
import sys

_repo = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))
sys.path.insert(0, _repo)

from timetraveller.worker import main

if __name__ == "__main__":
    sys.exit(main())
