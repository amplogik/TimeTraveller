"""Schedule editor: full day/time, incr days/time, cron preview, install buttons."""

from __future__ import annotations

from dataclasses import replace

from PyQt6.QtCore import Qt, pyqtSignal
from PyQt6.QtGui import QFont
from PyQt6.QtWidgets import (
    QCheckBox, QComboBox, QFormLayout, QGroupBox, QHBoxLayout, QLabel,
    QPlainTextEdit, QPushButton, QTimeEdit, QVBoxLayout, QWidget,
)
from PyQt6.QtCore import QTime

from ..config import WEEKDAYS, FullSchedule, IncrSchedule, PlanConfig, Schedule
from ..schedule import render_block

DAY_LABELS = [("mon", "Mon"), ("tue", "Tue"), ("wed", "Wed"), ("thu", "Thu"),
              ("fri", "Fri"), ("sat", "Sat"), ("sun", "Sun")]


class SchedulePanel(QWidget):
    changed = pyqtSignal()
    install_requested = pyqtSignal(bool)  # True=install, False=uninstall

    def __init__(self, parent=None):
        super().__init__(parent)
        self._plan: PlanConfig | None = None

        layout = QVBoxLayout(self)

        # Full schedule.
        full_box = QGroupBox("Full backup")
        fl = QFormLayout(full_box)
        self._full_day = QComboBox()
        for code, label in DAY_LABELS:
            self._full_day.addItem(label, code)
        self._full_time = QTimeEdit()
        self._full_time.setDisplayFormat("HH:mm")
        fl.addRow("Day of week:", self._full_day)
        fl.addRow("Time:", self._full_time)
        layout.addWidget(full_box)

        # Incremental schedule.
        incr_box = QGroupBox("Incremental backup")
        il = QVBoxLayout(incr_box)
        days_row = QHBoxLayout()
        days_row.addWidget(QLabel("Days:"))
        self._incr_days: dict[str, QCheckBox] = {}
        for code, label in DAY_LABELS:
            cb = QCheckBox(label)
            cb.toggled.connect(self.changed.emit)
            days_row.addWidget(cb)
            self._incr_days[code] = cb
        days_row.addStretch(1)
        il.addLayout(days_row)
        time_row = QHBoxLayout()
        time_row.addWidget(QLabel("Time:"))
        self._incr_time = QTimeEdit()
        self._incr_time.setDisplayFormat("HH:mm")
        time_row.addWidget(self._incr_time)
        time_row.addStretch(1)
        il.addLayout(time_row)
        layout.addWidget(incr_box)

        # Cron preview.
        preview_box = QGroupBox("Cron entries that will be installed")
        pl = QVBoxLayout(preview_box)
        self._preview = QPlainTextEdit()
        self._preview.setReadOnly(True)
        mono = QFont("Monospace")
        mono.setStyleHint(QFont.StyleHint.TypeWriter)
        self._preview.setFont(mono)
        self._preview.setMaximumHeight(140)
        pl.addWidget(self._preview)
        layout.addWidget(preview_box)

        # Install / Uninstall.
        btn_row = QHBoxLayout()
        self._install_btn = QPushButton("Install schedule")
        self._uninstall_btn = QPushButton("Uninstall schedule")
        btn_row.addWidget(self._install_btn)
        btn_row.addWidget(self._uninstall_btn)
        btn_row.addStretch(1)
        layout.addLayout(btn_row)
        layout.addStretch(1)

        # Hookups.
        self._full_day.currentIndexChanged.connect(self._on_changed)
        self._full_time.timeChanged.connect(self._on_changed)
        self._incr_time.timeChanged.connect(self._on_changed)
        for cb in self._incr_days.values():
            cb.toggled.connect(self._on_changed)
        self._install_btn.clicked.connect(lambda: self.install_requested.emit(True))
        self._uninstall_btn.clicked.connect(lambda: self.install_requested.emit(False))

    def load_plan(self, plan: PlanConfig) -> None:
        self._plan = plan
        # Full.
        idx = max(0, self._full_day.findData(plan.schedule.full.day))
        self._full_day.setCurrentIndex(idx)
        h, m = self._parse_time(plan.schedule.full.time)
        self._full_time.setTime(QTime(h, m))
        # Incr.
        active = set(plan.schedule.incr.days)
        for code, cb in self._incr_days.items():
            cb.setChecked(code in active)
        h, m = self._parse_time(plan.schedule.incr.time)
        self._incr_time.setTime(QTime(h, m))
        self._refresh_preview()

    def to_plan(self) -> PlanConfig:
        assert self._plan is not None
        full = FullSchedule(
            day=self._full_day.currentData(),
            time=self._full_time.time().toString("HH:mm"),
        )
        incr_days = [code for code, cb in self._incr_days.items() if cb.isChecked()]
        # Preserve weekday ordering: mon..sun
        incr_days.sort(key=lambda d: WEEKDAYS.index(d))
        incr = IncrSchedule(
            days=incr_days,
            time=self._incr_time.time().toString("HH:mm"),
        )
        return replace(self._plan, schedule=Schedule(full=full, incr=incr))

    def _on_changed(self) -> None:
        self._refresh_preview()
        self.changed.emit()

    def _refresh_preview(self) -> None:
        if not self._plan:
            return
        try:
            proposed = self.to_plan()
            # Show the dev path in the preview since installed-path may not exist yet.
            block = render_block(proposed, "/usr/local/bin/timetraveller-backup")
            self._preview.setPlainText(block)
        except Exception as e:  # noqa: BLE001
            self._preview.setPlainText(f"(invalid schedule: {e})")

    @staticmethod
    def _parse_time(hhmm: str) -> tuple[int, int]:
        parts = hhmm.split(":")
        return int(parts[0]), int(parts[1])
